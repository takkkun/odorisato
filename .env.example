MICROCMS_SERVICE_DOMAIN=your-service-name
MICROCMS_API_KEY=your-api-key

# Cloudflare Worker URL for the promote admin page (optional in dev).
# Set on the preview site's build to enable the /promote action.
# PUBLIC_WORKER_URL=https://odorisato-promote.your-subdomain.workers.dev

# GA4 Measurement ID. The site only loads gtag.js on the production
# hostname (odorisato.com), so leaving this set on preview is safe.
# PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

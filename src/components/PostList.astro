---
import type { Post } from '../data/types';
import Pagination from './Pagination.astro';

interface Props {
  posts: Post[];
  currentPage: number;
  totalPages: number;
  basePath: string; // '/', '/works', '/illust'
}

const { posts, currentPage, totalPages, basePath } = Astro.props;

function pageHref(page: number): string {
  if (page === 1) {
    return basePath === '/' ? '/' : basePath;
  }
  const prefix = basePath === '/' ? '' : basePath;
  return `${prefix}/page/${page}`;
}

const pages = Array.from({ length: totalPages }, (_, i) => ({
  num: i + 1,
  href: pageHref(i + 1),
  current: i + 1 === currentPage,
}));
const prevHref = currentPage > 1 ? pageHref(currentPage - 1) : null;
const nextHref = currentPage < totalPages ? pageHref(currentPage + 1) : null;

function postHref(postId: string): string {
  return basePath === '/' ? `/posts/${postId}` : `${basePath}/posts/${postId}`;
}
---

<ul id="posts">
  {
    posts.map((post) => (
      <li>
        <a href={postHref(post.id)} class="thumbnail">
          <img
            src={post.thumbnail.url}
            width={260}
            height={156}
            alt={post.caption || ''}
            loading="lazy"
          />
        </a>
        <a href={postHref(post.id)} class="thumbnail-for-smartphone">
          <img src={post.thumbnail.url} alt={post.caption || ''} loading="lazy" />
        </a>
      </li>
    ))
  }
</ul>

<Pagination pages={pages} prevHref={prevHref} nextHref={nextHref} />

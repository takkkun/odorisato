---
import Default from '../../../layouts/Default.astro';
import PostList from '../../../components/PostList.astro';
import {
  getCategories,
  getPostsByCategory,
  imageDefaultSrc,
  imageSrcset,
  paginate,
  POSTS_PER_PAGE,
} from '../../../data/content';

export async function getStaticPaths() {
  const categories = await getCategories();
  const paths = [];
  for (const category of categories) {
    const posts = await getPostsByCategory(category.name);
    for (const post of posts) {
      paths.push({
        params: { category: category.name, id: post.id },
        props: { post, categoryName: category.name },
      });
    }
  }
  return paths;
}

const { post, categoryName } = Astro.props;

const firstImage = post.images[0];
const basePath = `/${categoryName}`;
const closeHref = `${basePath}/`;

const imagesPayload = post.images.map((img) => ({
  url: img.url,
  width: img.width,
  height: img.height,
}));

// Background list = the category page that contains this post.
const categoryPosts = await getPostsByCategory(categoryName);
const xIndex = categoryPosts.findIndex((p) => p.id === post.id);
const pageNumber = xIndex >= 0 ? Math.floor(xIndex / POSTS_PER_PAGE) + 1 : 1;
const { items: bgItems, totalPages: bgTotalPages, currentPage: bgCurrentPage } = paginate(
  categoryPosts,
  pageNumber,
  POSTS_PER_PAGE
);
---

<Default
  title={post.caption || `post ${post.id}`}
  description={post.caption || undefined}
  ogImage={post.thumbnail.url}
>
  <PostList
    posts={bgItems}
    currentPage={bgCurrentPage}
    totalPages={bgTotalPages}
    basePath={basePath}
  />
  <div id="post" data-close-fallback={closeHref}>
    <div class="post-container">
      <div
        class="image-frame"
        data-images={JSON.stringify(imagesPayload)}
        style={
          firstImage
            ? `--ar: ${firstImage.width / firstImage.height}; --max-w: ${firstImage.width}px;`
            : undefined
        }
      >
        {
          firstImage && (
            <img
              src={imageDefaultSrc(firstImage.url, firstImage.width)}
              srcset={imageSrcset(firstImage.url, firstImage.width)}
              sizes="(max-width: 480px) 100vw, calc(100vw - 40px)"
              width={firstImage.width}
              height={firstImage.height}
              alt={post.caption || ''}
              class="current-image"
            />
          )
        }
        {
          post.caption && (
            <h2 class="caption">
              <span>{post.caption}</span>
            </h2>
          )
        }
        {
          post.images.length > 1 && (
            <>
              <a href="#" class="button shift previous" rel="nofollow" aria-label="previous">
                <span>
                  <svg
                    class="icon-chevron"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <polyline points="10,3 5,8 10,13" />
                  </svg>
                </span>
              </a>
              <a href="#" class="button shift next" rel="nofollow" aria-label="next">
                <span>
                  <svg
                    class="icon-chevron"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <polyline points="6,3 11,8 6,13" />
                  </svg>
                </span>
              </a>
            </>
          )
        }
        <ul class="means">
          {
            firstImage && (
              <li>
                <a
                  href={firstImage.url}
                  class="button original"
                  target="_blank"
                  rel="nofollow noopener"
                  aria-label="open original"
                >
                  <svg
                    class="icon-action"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <line x1="5" y1="11" x2="11" y2="5" />
                    <polyline points="6,5 11,5 11,10" />
                  </svg>
                </a>
              </li>
            )
          }
          <li class="divider"></li>
          <li>
            <a href={closeHref} class="button close" rel="nofollow" aria-label="close">
              <svg
                class="icon-action"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                aria-hidden="true"
              >
                <line x1="4" y1="4" x2="12" y2="12" />
                <line x1="12" y1="4" x2="4" y2="12" />
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Default>

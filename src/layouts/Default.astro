---
import '../styles/global.scss';
import '../styles/utilities.scss';
import '../styles/link.scss';
import '../styles/notification.scss';
import '../styles/profile.scss';
import '../styles/posts.scss';

import { PUBLIC_GA4_MEASUREMENT_ID } from 'astro:env/client';
import Header from '../components/Header.astro';
import NotificationBar from '../components/NotificationBar.astro';
import { getCategories, getNotification } from '../data/content';

const ga4Id = PUBLIC_GA4_MEASUREMENT_ID ?? '';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage,
  noindex = false,
} = Astro.props;

const siteName = 'ODORI SATO';
const fullTitle = title ? `${title} | ${siteName}` : siteName;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const categories = await getCategories();
const notification = await getNotification();
const showNotification = !Astro.url.pathname.startsWith('/profile');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{fullTitle}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    {description && <meta property="og:description" content={description} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <script is:inline define:vars={{ ga4Id }}>
      if (ga4Id && window.location.hostname === 'odorisato.com') {
        window.dataLayer = window.dataLayer || [];
        window.gtag = function () { window.dataLayer.push(arguments); };
        window.gtag('js', new Date());
        window.gtag('config', ga4Id);
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + ga4Id;
        document.head.appendChild(s);
      }
    </script>
  </head>
  <body>
    <div id="container">
      <Header categories={categories} currentPath={Astro.url.pathname} />
      {showNotification && <NotificationBar content={notification.content} />}
      <div id="body">
        <slot />
      </div>
    </div>
    <script>
      import { initImageViewer } from '../scripts/imageViewer';
      import { renderEmails } from '../scripts/email';
      import { initOverlayRouter } from '../scripts/overlayRouter';

      initImageViewer();
      renderEmails();
      initOverlayRouter();
    </script>
  </body>
</html>
